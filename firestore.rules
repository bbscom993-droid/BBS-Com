rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Default Deny Gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Company Settings Validation
    function isValidCompanySettings(data) {
      return data.keys().hasAll(['companyName', 'whatsapp', 'email'])
        && data.companyName is string && data.companyName.size() <= 200
        && data.whatsapp is string && data.whatsapp.size() <= 50
        && data.email is string && data.email.size() <= 100;
    }

    match /settings/config {
      allow read: if true; // Public company settings
      allow write: if isSignedIn() && isEmailVerified() && isValidCompanySettings(request.resource.data);
    }

    // 3. RFQ Validation
    function isValidRFQ(data) {
      return data.keys().hasAll(['id', 'rfqNumber', 'date', 'status', 'clientName', 'whatsapp', 'email'])
        && isValidId(data.id)
        && data.rfqNumber is string && data.rfqNumber.size() <= 50
        && data.date is string && data.date.size() <= 20
        && data.status in ['pending', 'quoted', 'rejected']
        && data.clientName is string && data.clientName.size() <= 200
        && data.whatsapp is string && data.whatsapp.size() <= 50
        && data.email is string && data.email.size() <= 100;
    }

    match /rfqs/{rfqId} {
      allow get: if isSignedIn() && isValidId(rfqId);
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email;
      allow create: if isValidId(rfqId) && isValidRFQ(request.resource.data);
      allow update: if isSignedIn() && isValidId(rfqId) && isValidRFQ(request.resource.data)
        && (request.resource.data.status != resource.data.status || request.resource.data.notes != resource.data.notes);
      allow delete: if isSignedIn() && isEmailVerified() && isValidId(rfqId);
    }

    // 4. Quotation Validation
    function isValidQuotation(data) {
      return data.keys().hasAll(['id', 'rfqId', 'quotationNumber', 'date', 'status', 'subtotal', 'total'])
        && isValidId(data.id)
        && isValidId(data.rfqId)
        && data.quotationNumber is string && data.quotationNumber.size() <= 50
        && data.date is string && data.date.size() <= 20
        && data.status in ['draft', 'sent', 'accepted', 'expired']
        && data.subtotal is number
        && data.total is number;
    }

    match /quotations/{quotationId} {
      allow get: if isSignedIn() && isValidId(quotationId);
      allow list: if isSignedIn();
      allow write: if isSignedIn() && isEmailVerified() && isValidId(quotationId) && isValidQuotation(request.resource.data);
    }

    // 5. Catalog Products
    function isValidCatalogProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'description', 'estimatedPriceRange'])
        && isValidId(data.id)
        && data.name is string && data.name.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.description is string && data.description.size() <= 2000
        && data.estimatedPriceRange is string && data.estimatedPriceRange.size() <= 100;
    }

    match /catalog/{productId} {
      allow read: if true; // Public catalog access
      allow write: if isSignedIn() && isEmailVerified() && isValidId(productId) && isValidCatalogProduct(request.resource.data);
    }

    // 6. Emails Log
    match /emails/{emailId} {
      allow read, write: if isSignedIn() && isEmailVerified() && isValidId(emailId);
    }

    // 7. Reminders
    match /reminders/{reminderId} {
      allow read, write: if isSignedIn() && isEmailVerified() && isValidId(reminderId);
    }
  }
}
